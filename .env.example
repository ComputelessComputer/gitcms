# Public origin of the CMS, used for OAuth redirects and deploy docs.
GITCMS_APP_URL=http://localhost:3000

# Optional path to gitcms.config.ts. Defaults to ./gitcms.config.ts.
GITCMS_CONFIG_PATH=./gitcms.config.ts

# Storage backend to use: supabase, s3, github, or local.
GITCMS_STORAGE_BACKEND=supabase

# Auth provider: github (default, zero-config) or jwt (Clerk/WorkOS/Auth0/Supabase Auth).
GITCMS_AUTH_MODE=github

# GitHub token source: oauth (use signed-in user's token) or service (fixed PAT).
# Must be 'service' when AUTH_MODE=jwt.
GITCMS_GITHUB_TOKEN_SOURCE=oauth

# 32+ byte random secret used to seal the encrypted session cookie. Required for AUTH_MODE=github.
SESSION_SECRET=

# Members allowlist. Format: identifier:role,identifier:role
# - Identifier matches identity.login, identity.email, or identity.subject (case-insensitive).
# - Role defaults to admin. Only "admin" is supported in v0.1.
# Example: johnjeong:admin,john@fastrepl.com:admin
GITCMS_MEMBERS=

# Legacy v0.0.x allowlist — used as a fallback when GITCMS_MEMBERS is unset.
GITCMS_ADMIN_LOGINS=

# ---- AUTH_MODE=github ----

# GitHub OAuth app client ID.
GITHUB_OAUTH_CLIENT_ID=

# GitHub OAuth app client secret.
GITHUB_OAUTH_CLIENT_SECRET=

# Absolute callback URL registered in the GitHub OAuth app.
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# ---- AUTH_MODE=jwt ----

# Issuer URL of your identity provider (must match `iss` claim).
GITCMS_AUTH_JWT_ISSUER=

# Audience your tokens are minted for (must match `aud` claim).
GITCMS_AUTH_JWT_AUDIENCE=

# Public JWKS endpoint of your provider for signature verification.
GITCMS_AUTH_JWT_JWKS_URL=

# Cookie name to read the bearer token from (Authorization header is checked first).
GITCMS_AUTH_JWT_COOKIE_NAME=gitcms_jwt

# Override claim names if your provider uses non-standard names.
GITCMS_AUTH_JWT_CLAIM_SUBJECT=sub
GITCMS_AUTH_JWT_CLAIM_EMAIL=email
GITCMS_AUTH_JWT_CLAIM_LOGIN=preferred_username
GITCMS_AUTH_JWT_CLAIM_NAME=name
GITCMS_AUTH_JWT_CLAIM_AVATAR=picture

# ---- GITCMS_GITHUB_TOKEN_SOURCE=service ----

# Fixed GitHub token used for content writes when TOKEN_SOURCE=service.
# Recommended: fine-grained PAT or GitHub App installation token, scoped to contents:write.
GITCMS_GITHUB_SERVICE_TOKEN=

# ---- Storage: Supabase ----

# Supabase project URL, used when GITCMS_STORAGE_BACKEND=supabase.
SUPABASE_URL=

# Supabase service role key, used only on the server.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Storage bucket for media.
SUPABASE_MEDIA_BUCKET=gitcms-media

# ---- Storage: S3-compatible ----

# S3-compatible endpoint, used when GITCMS_STORAGE_BACKEND=s3.
S3_ENDPOINT=https://s3.amazonaws.com

# S3-compatible region.
S3_REGION=us-east-1

# S3-compatible bucket for media.
S3_BUCKET=gitcms-media

# S3-compatible access key ID.
S3_ACCESS_KEY_ID=

# S3-compatible secret access key.
S3_SECRET_ACCESS_KEY=

# Optional CDN/public base URL for S3 media. Falls back to bucket URL.
S3_PUBLIC_URL_BASE=

# Set true for MinIO, Cloudflare R2, Backblaze B2, and other path-style providers.
S3_FORCE_PATH_STYLE=false

# ---- Storage: GitHub-as-storage ----

# GitHub-as-storage: owner/repo to commit media into. Often the same as your content repo.
GITCMS_GITHUB_MEDIA_REPO=

# Branch to commit media to. Defaults to the repo's default branch.
GITCMS_GITHUB_MEDIA_BRANCH=

# Path within the repo where media lives.
GITCMS_GITHUB_MEDIA_PATH=public/uploads

# Fine-grained PAT or service token with contents:write on the media repo.
GITCMS_GITHUB_MEDIA_TOKEN=

# Set true if the media repo is public (uses raw.githubusercontent.com URLs).
GITCMS_GITHUB_MEDIA_PUBLIC=true

# Optional CDN/proxy in front of raw.githubusercontent.com (jsDelivr, Cloudflare, etc).
GITCMS_GITHUB_MEDIA_PUBLIC_URL_BASE=

# ---- Storage: Local filesystem ----

# Filesystem media root, used when GITCMS_STORAGE_BACKEND=local.
LOCAL_STORAGE_ROOT=./LOCAL_STORAGE_ROOT

# Public URL prefix for local media, used when GITCMS_STORAGE_BACKEND=local.
LOCAL_STORAGE_PUBLIC_URL=http://localhost:3000/media
