{
  "name": "gitcms",
  "version": "0.0.1",
  "description": "Self-hostable git-based CMS with pluggable media storage.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "routegen": "tsr generate",
    "typecheck": "pnpm routegen && tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "gitcms:init-context": "node scripts/init-context.mjs",
    "format": "prettier --check ."
  },
  "exports": {
    "./config": "./src/config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "latest",
    "@aws-sdk/s3-request-presigner": "latest",
    "@octokit/auth-oauth-app": "latest",
    "@octokit/rest": "latest",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-dropdown-menu": "latest",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-slot": "latest",
    "@supabase/supabase-js": "latest",
    "@tailwindcss/vite": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-start": "latest",
    "@tiptap/extension-image": "latest",
    "@tiptap/extension-link": "latest",
    "@tiptap/extension-placeholder": "latest",
    "@tiptap/extension-table": "latest",
    "@tiptap/extension-table-cell": "latest",
    "@tiptap/extension-table-header": "latest",
    "@tiptap/extension-table-row": "latest",
    "@tiptap/react": "latest",
    "@tiptap/starter-kit": "latest",
    "clsx": "latest",
    "cookie": "latest",
    "iron-session": "latest",
    "jiti": "latest",
    "jose": "^6.2.3",
    "js-yaml": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwind-merge": "latest",
    "unified": "^11.0.5",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@tailwindcss/postcss": "latest",
    "@tanstack/router-cli": "latest",
    "@types/cookie": "latest",
    "@types/js-yaml": "latest",
    "@types/mdast": "^4.0.4",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "nitro": "latest",
    "prettier": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vite-tsconfig-paths": "latest",
    "vitest": "latest"
  },
  "packageManager": "pnpm@10.33.0"
}
